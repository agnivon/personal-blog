{
  "name": "personal-blog",
  "version": "1.0.0",
  "scripts": {
    "predev": "yarn typegen",
    "convex-dev": "convex dev",
    "convex-deploy": "convex deploy",
    "next-dev": "next --turbo",
    "dev": "concurrently \"convex dev\" \"next --turbo\"",
    "test": "vitest",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "prebuild": "yarn typegen",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "presetup": "echo 'about to setup env variables, follow the guide here: https://github.com/vercel/next.js/tree/canary/examples/cms-sanity#using-the-sanity-cli'",
    "setup": "npx sanity@latest init --env .env.local",
    "postsetup": "echo 'create the read token by following the rest of the guide: https://github.com/vercel/next.js/tree/canary/examples/cms-sanity#creating-a-read-token'",
    "typegen": "sanity schema extract && sanity typegen generate"
  },
  "dependencies": {
    "@google/genai": "^1.8.0",
    "@opentelemetry/api": "^1.9.0",
    "@portabletext/block-tools": "^1.1.37",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@sanity/assist": "^3.0.8",
    "@sanity/icons": "^3.4.0",
    "@sanity/image-url": "^1.0.2",
    "@sanity/preview-url-secret": "^2.0.0",
    "@sanity/vision": "^3.62.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.7.8",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vercel/speed-insights": "^1.0.13",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.25.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.525.0",
    "next": "15.5.14",
    "next-sanity": "^9.7.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanity": "^3.62.0",
    "sanity-plugin-asset-source-unsplash": "^3.0.1",
    "server-only": "^0.0.1",
    "shadcn-prose": "^1.0.12",
    "showdown": "^2.1.0",
    "styled-components": "^6.1.13",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "typescript": "5.6.3",
    "xmldom": "^0.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/showdown": "^2.0.6",
    "@types/xmldom": "^0.1.34",
    "concurrently": "^9.2.0",
    "convex-test": "^0.0.37",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.0",
    "tw-animate-css": "^1.3.5",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  },
  "packageManager": "yarn@4.6.0"
}
